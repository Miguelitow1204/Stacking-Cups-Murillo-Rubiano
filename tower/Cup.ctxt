#BlueJ class context
comment0.target=Cup
comment0.text=\r\n\ Cup\ -\ Represents\ a\ cup\ in\ the\ stacking\ tower.\r\n\ The\ base\ of\ the\ cup\ is\ 1\ cm.\r\n\ \r\n\ C4\ -\ Abstract\ base\ class\ for\ all\ cup\ types.\r\n\ \r\n\ @author\ (Murillo-Rubiano)\r\n\ @version\ (2.5)\r\n
comment1.params=idNumC
comment1.target=Cup(int)
comment1.text=\r\n\ Constructor\ for\ normal\ cup\r\n\ \r\n\ @param\ idNumC\r\n
comment10.params=
comment10.target=void\ erase()
comment10.text=\r\n\ Erases\ the\ cup\ from\ the\ canvas\r\n
comment11.params=
comment11.target=void\ makeVisible()
comment11.text=\r\n\ Makes\ the\ cup\ visible\r\n
comment12.params=
comment12.target=void\ makeInvisible()
comment12.text=\r\n\ Makes\ the\ cup\ invisible\r\n
comment13.params=lid
comment13.target=void\ pairWith(Lid)
comment13.text=\r\n\ Pairs\ this\ cup\ with\ a\ lid\r\n\ \r\n\ @param\ lid\ The\ lid\ to\ pair\ with\r\n
comment14.params=
comment14.target=void\ unpair()
comment14.text=\r\n\ Unpairs\ this\ cup\ from\ its\ lid\r\n
